# Supabase (free at supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Hugging Face (free token at huggingface.co/settings/tokens)
HF_API_TOKEN=hf_your_token

# Google Custom Search (free 100 queries/day)
# 1. Create project: console.cloud.google.com -> enable "Custom Search API"
# 2. Get API key from Credentials page
GOOGLE_API_KEY=your_google_api_key
# 3. Create search engine: cse.google.com -> "Control Panel" -> get cx
GOOGLE_CSE_ID=your_cse_id

# Bing Search (free 1000 queries/month at azure.com)
BING_API_KEY=your_bing_api_key
